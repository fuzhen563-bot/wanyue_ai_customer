# 重启服务
restart_service() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}                           重启服务                                         ${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    echo -e "${YELLOW}▸ 重启Python服务...${NC}"
    pkill -f "uvicorn main:app" 2>/dev/null || true
    sleep 1
    cd $INSTALL_DIR
    nohup uvicorn main:app --host 0.0.0.0 --port 8000 > $INSTALL_DIR/server.log 2>&1 &
    sleep 2
    
    if pgrep -f "uvicorn main:app" > /dev/null; then
        echo -e "  ✓ Python服务已重启"
    else
        echo -e "  ✗ Python服务启动失败"
    fi
    
    echo ""
    echo -e "${YELLOW}▸ 重启Nginx...${NC}"
    nginx -s reload 2>/dev/null || systemctl reload nginx 2>/dev/null || true
    echo -e "  ✓ Nginx已重启"
    
    echo ""
    echo -e "${GREEN}✓ 服务重启完成${NC}"
    
    load_config
    if [ -n "$DOMAIN" ]; then
        if [ -f /etc/letsencrypt/live/$DOMAIN/fullchain.pem ]; then
            echo -e "${GREEN}访问地址: https://${DOMAIN}${NC}"
        else
            echo -e "${GREEN}访问地址: http://${DOMAIN}${NC}"
        fi
    else
        echo -e "${GREEN}访问地址: http://$(get_server_ip):8000${NC}"
    fi
    
    read -p "按回车键继续..."
}

