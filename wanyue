    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    # 显示当前配置
    load_config
    echo -e "${YELLOW}当前配置:${NC}"
    echo -e "  • 服务器IP: ${SERVER_IP}"
    echo -e "  • 域名: ${DOMAIN:-未绑定}"
    echo ""
    
    # 输入新域名
    echo -ne "${GREEN}请输入新域名（新域名需已解析到本服务器）: ${NC}"
    read NEW_DOMAIN
    
    if [ -z "$NEW_DOMAIN" ]; then
        echo -e "${RED}域名不能为空${NC}"
        return
    fi
    
    # 检查DNS
    echo -e "${YELLOW}▸ 检查DNS解析...${NC}"
    DOMAIN_IP=$(dig +short $NEW_DOMAIN 2>/dev/null | tail -1)
    SERVER_IP=$(get_server_ip)
    
    if [ "$DOMAIN_IP" != "$SERVER_IP" ]; then
        echo -e "${RED}✗ 错误: 域名未解析到本服务器${NC}"
        echo -e "${RED}  域名解析: ${DOMAIN_IP}${NC}"
        echo -e "${RED}  服务器IP: ${SERVER_IP}${NC}"
        echo -ne "${YELLOW}是否强制继续? [y/N]: ${NC}"
        read CONFIRM
        if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
            return
        fi
    fi
    
    # 询问SSL
    echo ""
    echo -e "${YELLOW}是否配置HTTPS/SSL？${NC}"
    echo "  1) 使用Let's Encrypt免费SSL（推荐）"
    echo "  2) 仅HTTP（不配置SSL）"
    echo "  3) 使用已有SSL证书"
    echo -ne "${GREEN}请输入选项 [1-3]: ${NC}"
    read SSL_OPTION
    
    # 更新Nginx配置
    echo ""
    echo -e "${YELLOW}▸ 更新Nginx配置...${NC}"
    
    case $SSL_OPTION in
        1)
            # 先配置HTTP
            cat > /etc/nginx/sites-available/wanyue-ai << EOF
server {
    listen 80;
    server_name $NEW_DOMAIN;
    
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
    }
    
    location /static {
        alias $INSTALL_DIR/app/static;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
EOF
            ln -sf /etc/nginx/sites-available/wanyue-ai /etc/nginx/sites-enabled/
            nginx -t && nginx -s reload
            
            # 申请SSL证书
            echo -e "${YELLOW}▸ 申请Let's Encrypt SSL证书...${NC}"
            certbot --nginx -d $NEW_DOMAIN --non-interactive --agree-tos --email admin@$NEW_DOMAIN 2>/dev/null || {
                echo -e "${YELLOW}  ⚠ SSL申请失败，已配置HTTP${NC}"
            }
            
            if [ -f /etc/letsencrypt/live/$NEW_DOMAIN/fullchain.pem ]; then
