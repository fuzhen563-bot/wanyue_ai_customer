# 系统状态检测
check_system() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}                           系统状态检测                                     ${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    # 检测服务状态
    echo -e "${YELLOW}▸ 检测服务状态...${NC}"
    if pgrep -f "uvicorn main:app" > /dev/null; then
        echo -e "  ✓ Python服务运行中"
    else
        echo -e "  ✗ Python服务未运行"
    fi
    
    if systemctl is-active --quiet nginx 2>/dev/null; then
        echo -e "  ✓ Nginx运行中"
    elif pgrep -f "nginx" > /dev/null; then
        echo -e "  ✓ Nginx运行中"
    else
        echo -e "  ✗ Nginx未运行"
    fi
    
    # 检测端口
    echo ""
    echo -e "${YELLOW}▸ 检测端口监听...${NC}"
    if netstat -tuln 2>/dev/null | grep -q ":8000 "; then
        echo -e "  ✓ 8000端口监听中"
    else
        echo -e "  ✗ 8000端口未监听"
    fi
    
    if netstat -tuln 2>/dev/null | grep -q ":80 "; then
        echo -e "  ✓ 80端口监听中"
    else
        echo -e "  ✗ 80端口未监听"
    fi
    
    # 检测Nginx配置
    echo ""
    echo -e "${YELLOW}▸ 检测Nginx配置...${NC}"
    if [ -f /etc/nginx/sites-enabled/wanyue-ai ]; then
        echo -e "  ✓ Nginx配置文件存在"
        DOMAIN=$(grep "server_name" /etc/nginx/sites-enabled/wanyue-ai | head -1 | awk '{print $2}' | sed 's/;$//')
        echo -e "  • 绑定域名: ${DOMAIN:-未绑定}"
    else
        echo -e "  ✗ Nginx配置文件不存在"
    fi
    
    # 检测数据库
    echo ""
    echo -e "${YELLOW}▸ 检测数据库...${NC}"
    if [ -f $INSTALL_DIR/wanyue_ai.db ]; then
        echo -e "  ✓ 数据库文件存在"
        DB_SIZE=$(du -h $INSTALL_DIR/wanyue_ai.db | cut -f1)
        echo -e "  • 数据库大小: $DB_SIZE"
    else
        echo -e "  ✗ 数据库文件不存在"
    fi
    
    # 检测依赖
    echo ""
    echo -e "${YELLOW}▸ 检测Python依赖...${NC}"
    if python3 -c "import fastapi" 2>/dev/null; then
        echo -e "  ✓ FastAPI已安装"
    else
        echo -e "  ✗ FastAPI未安装"
    fi
    
    if python3 -c "import uvicorn" 2>/dev/null; then
        echo -e "  ✓ Uvicorn已安装"
    else
        echo -e "  ✗ Uvicorn未安装"
    fi
    
    # 服务器信息
    echo ""
    echo -e "${YELLOW}▸ 服务器信息...${NC}"
    echo -e "  • 服务器IP: $(get_server_ip)"
    echo -e "  • 服务器时间: $(date '+%Y-%m-%d %H:%M:%S')"
    echo -e "  • 负载: $(uptime | awk -F'load average:' '{print $2}')"
    
    echo ""
    read -p "按回车键继续..."
}

# 一键安装
install_from_remote() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}                           一键安装                                         ${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    echo -e "${YELLOW}请选择程序来源：${NC}"
    echo "  1) GitHub (https://github.com/fuzhen563-bot/wanyue_ai_customer.git)"
    echo "  2) Gitee (https://gitee.com/xingdezone/wanyue_ai_customer.git)"
    echo "  3) 手动输入URL"
    echo -ne "${GREEN}请输入选项 [1-3]: ${NC}"
    read SOURCE_CHOICE
    
    case $SOURCE_CHOICE in
        1)
            DOWNLOAD_URL="https://github.com/fuzhen563-bot/wanyue_ai_customer.git"
            ;;
        2)
            DOWNLOAD_URL="https://gitee.com/xingdezone/wanyue_ai_customer.git"
            ;;
        3)
            echo -ne "${GREEN}请输入程序下载链接: ${NC}"
            read DOWNLOAD_URL
            ;;
        *)
            echo -e "${RED}无效选项${NC}"
            return
            ;;
    esac
    
    if [ -z "$DOWNLOAD_URL" ]; then
        echo -e "${RED}下载地址不能为空${NC}"
        return
    fi
    
    echo ""
    echo -e "${YELLOW}▸ 下载程序...${NC}"
    
    TEMP_DIR="/tmp/wanyue_install_$$"
    mkdir -p "$TEMP_DIR"
    cd "$TEMP_DIR"
    
    # 判断是否为git仓库
    if [[ "$DOWNLOAD_URL" == *.git ]]; then
        # 检测是否为中国大陆网络（通过尝试访问国内网站判断）
        CN_CHECK=$(curl -s -m 3 https://www.baidu.com -o /dev/null -w "%{http_code}" 2>/dev/null || echo "failed")
        if [ "$CN_CHECK" = "200" ] || [ "$CN_CHECK" = "301" ] || [ "$CN_CHECK" = "302" ]; then
            echo -e "  • 检测为大陆网络，使用镜像加速..."
            # 替换GitHub为镜像
            if [[ "$DOWNLOAD_URL" == *"github.com"* ]]; then
                DOWNLOAD_URL="${DOWNLOAD_URL//github.com/ghproxy.com/}"
            fi
        fi
        
        if git clone "$DOWNLOAD_URL" wanyue_program 2>/dev/null; then
            echo -e "  ✓ 下载完成"
            cd wanyue_program
        else
            # 如果镜像失败，尝试原始地址
            if [[ "$DOWNLOAD_URL" == *"ghproxy.com"* ]]; then
                ORIGINAL_URL="${DOWNLOAD_URL//ghproxy.com\/}"
                if git clone "$ORIGINAL_URL" wanyue_program 2>/dev/null; then
                    echo -e "  ✓ 下载完成（使用原始地址）"
                    cd wanyue_program
                else
                    echo -e "${RED}下载失败，请检查链接是否正确${NC}"
                    rm -rf "$TEMP_DIR"
                    read -p "按回车键继续..."
                    return
                fi
            else
                echo -e "${RED}下载失败，请检查链接是否正确${NC}"
                rm -rf "$TEMP_DIR"
                read -p "按回车键继续..."
                return
            fi
        fi
    else
        if curl -L -o program.tar.gz "$DOWNLOAD_URL" 2>/dev/null; then
            echo -e "  ✓ 下载完成"
            
            echo ""
            echo -e "${YELLOW}▸ 解压程序...${NC}"
            tar -xzf program.tar.gz 2>/dev/null || unzip -o program.tar.gz 2>/dev/null
            
            EXTRACTED_DIR=$(ls -d */ 2>/dev/null | head -1)
            if [ -n "$EXTRACTED_DIR" ]; then
                cd "$EXTRACTED_DIR"
            fi
        else
            echo -e "${RED}下载失败，请检查链接是否正确${NC}"
            rm -rf "$TEMP_DIR"
            read -p "按回车键继续..."
            return
        fi
    fi
    
    # 检查install.sh是否存在
    if [ -f "install.sh" ]; then
        echo ""
        echo -e "${YELLOW}▸ 设置执行权限...${NC}"
        chmod +x install.sh wanyue 2>/dev/null || true
        
        echo ""
        echo -e "${YELLOW}▸ 执行安装脚本...${NC}"
        echo -e "${YELLOW}  (安装过程请按提示操作)${NC}"
        echo ""
        bash install.sh
    else
        echo -e "${RED}未找到安装脚本 (install.sh)${NC}"
        echo -e "${YELLOW}请手动解压并运行安装脚本${NC}"
    fi
    
    rm -rf "$TEMP_DIR"
    
    read -p "按回车键继续..."
}

# 更换域名
change_domain() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
