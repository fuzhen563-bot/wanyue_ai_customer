NC='\033[0m'

# 获取服务器IP
get_server_ip() {
    SERVER_IP=$(curl -s https://api.ipify.org 2>/dev/null || curl -s https://ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
    echo "$SERVER_IP"
}

# 加载配置
load_config() {
    if [ -f "$INSTALL_DIR/.env.install" ]; then
        source "$INSTALL_DIR/.env.install"
    fi
    if [ -z "$SERVER_IP" ]; then
        SERVER_IP=$(get_server_ip)
    fi
}

