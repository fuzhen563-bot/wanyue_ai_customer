# 自动检测安装目录
get_install_dir() {
    local script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local script_name="$(basename "${BASH_SOURCE[0]}")"
    
    # 如果脚本在/usr/local/bin目录，尝试从符号链接获取真实路径
    if [[ "$(dirname "$script_path")" == "/usr/local/bin" ]]; then
        local real_path="$(readlink -f "$script_path" 2>/dev/null || echo "$script_path")"
        INSTALL_DIR="$(dirname "$real_path")"
    else
        INSTALL_DIR="$script_path"
    fi
    
    # 如果目录包含wanyue脚本，则认为是安装目录
    if [[ -f "$INSTALL_DIR/wanyue" ]]; then
        echo "$INSTALL_DIR"
    else
        echo "$INSTALL_DIR"
    fi
}

# 设置安装目录
INSTALL_DIR=$(get_install_dir)

