# 服务管理
service_manager() {
    while true; do
        echo ""
        echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
        echo -e "${CYAN}                           服务管理                                       ${NC}"
        echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
        echo ""
        
        # 检测状态
        if pgrep -f "uvicorn main:app" > /dev/null; then
            echo -e "  Python服务: ${GREEN}运行中${NC}"
        else
            echo -e "  Python服务: ${RED}已停止${NC}"
        fi
        
        if pgrep -f "nginx" > /dev/null; then
            echo -e "  Nginx: ${GREEN}运行中${NC}"
        else
            echo -e "  Nginx: ${RED}已停止${NC}"
        fi
        
        echo ""
        echo "  1) 启动Python服务"
        echo "  2) 停止Python服务"
        echo "  3) 重启Python服务"
        echo "  4) 启动Nginx"
        echo "  5) 停止Nginx"
        echo "  6) 重启Nginx"
        echo "  0) 返回主菜单"
        echo ""
        echo -ne "${CYAN}请输入选项 [0-6]: ${NC}"
        read SChoice
        
        case $SChoice in
            1)
                cd $INSTALL_DIR
                nohup uvicorn main:app --host 0.0.0.0 --port 8000 > $INSTALL_DIR/server.log 2>&1 &
                sleep 2
                echo -e "${GREEN}✓ Python服务已启动${NC}"
                ;;
            2)
                pkill -f "uvicorn main:app"
                echo -e "${GREEN}✓ Python服务已停止${NC}"
                ;;
            3)
                pkill -f "uvicorn main:app" 2>/dev/null || true
                sleep 1
                cd $INSTALL_DIR
                nohup uvicorn main:app --host 0.0.0.0 --port 8000 > $INSTALL_DIR/server.log 2>&1 &
                sleep 2
                echo -e "${GREEN}✓ Python服务已重启${NC}"
                ;;
            4)
                nginx 2>/dev/null || systemctl start nginx 2>/dev/null || true
                echo -e "${GREEN}✓ Nginx已启动${NC}"
                ;;
            5)
                nginx -s stop 2>/dev/null || systemctl stop nginx 2>/dev/null || pkill nginx || true
                echo -e "${GREEN}✓ Nginx已停止${NC}"
                ;;
            6)
                nginx -s reload 2>/dev/null || systemctl restart nginx 2>/dev/null || true
                echo -e "${GREEN}✓ Nginx已重启${NC}"
                ;;
            0)
                break
                ;;
        esac
    done
}

# 一键卸载
uninstall_system() {
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}                           一键卸载                                         ${RED}║${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    echo -e "${RED}⚠ 警告：此操作将执行以下操作：${NC}"
    echo "  1. 停止Python服务"
    echo "  2. 移除Nginx配置"
    echo "  3. 删除程序文件"
    echo "  4. 删除系统服务"
    echo "  5. 删除工具箱"
    echo ""
    echo -e "${YELLOW}注意：数据库文件默认会保留在 $INSTALL_DIR/wanyue_ai.db${NC}"
    echo ""
    echo -ne "${RED}是否继续卸载? [yes/no]: ${NC}"
    read confirm
    
    if [ "$confirm" != "yes" ]; then
        echo -e "${YELLOW}已取消卸载${NC}"
        return
    fi
    
    echo ""
    echo -e "${YELLOW}▸ 停止Python服务...${NC}"
    pkill -f "uvicorn main:app" 2>/dev/null || true
    echo -e "  ✓ 已停止"
    
    echo ""
    echo -e "${YELLOW}▸ 移除Nginx配置...${NC}"
    rm -f /etc/nginx/sites-enabled/wanyue-ai
    rm -f /etc/nginx/sites-available/wanyue-ai
    nginx -s reload 2>/dev/null || true
    echo -e "  ✓ 已移除"
    
    echo ""
    echo -e "${YELLOW}▸ 删除程序文件...${NC}"
    rm -rf $INSTALL_DIR
    echo -e "  ✓ 已删除"
    
    echo ""
    echo -e "${YELLOW}▸ 删除系统服务...${NC}"
    rm -f /etc/systemd/system/wanyue-ai.service
    systemctl daemon-reload 2>/dev/null || true
    echo -e "  ✓ 已删除"
    
    echo ""
    echo -e "${YELLOW}▸ 删除工具箱...${NC}"
    rm -f /usr/local/bin/wanyue
    echo -e "  ✓ 已删除"
    
    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║${NC}                         ${YELLOW}卸载完成！${NC}                                         ${GREEN}║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}如需重新安装，请运行：${NC}"
    echo "  bash $INSTALL_DIR/install.sh"
    echo ""
    
    exit 0
}

# 数据库维护
db_maintenance() {
    while true; do
        echo ""
        echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
        echo -e "${CYAN}                           数据库维护                                     ${NC}"
        echo -e "${CYAN}═══════════════════════════════════════════════════════════════════════════════${NC}"
        echo ""
        
        DB_PATH="$INSTALL_DIR/wanyue_ai.db"
        
        if [ -f "$DB_PATH" ]; then
            DB_SIZE=$(du -h "$DB_PATH" | cut -f1)
            echo -e "  数据库: ${DB_PATH}"
            echo -e "  大小: ${DB_SIZE}"
            
            # 简单的数据统计
            USER_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM users;" 2>/dev/null || echo "N/A")
            ORDER_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM orders;" 2>/dev/null || echo "N/A")
            echo -e "  用户数: ${USER_COUNT}"
            echo -e "  订单数: ${ORDER_COUNT}"
        else
            echo -e "${RED}数据库文件不存在${NC}"
        fi
        
        echo ""
        echo "  1) 备份数据库"
        echo "  2) 清理日志数据"
        echo "  3) 查看数据库表"
        echo "  0) 返回主菜单"
        echo ""
        echo -ne "${CYAN}请输入选项 [0-3]: ${NC}"
        read DChoice
        
        case $DChoice in
            1)
                BACKUP_FILE="$INSTALL_DIR/backup_$(date +%Y%m%d_%H%M%S).db"
                cp "$DB_PATH" "$BACKUP_FILE"
                echo -e "${GREEN}✓ 备份完成: ${BACKUP_FILE}${NC}"
                ;;
            2)
                echo -e "${YELLOW}清理30天前的会话数据...${NC}"
                python3 -c "
import sys
sys.path.insert(0, '$INSTALL_DIR')
from app.core.database import SessionLocal
from app.models.user import ChatSession, ChatMessage
from datetime import datetime, timedelta

db = SessionLocal()
try:
    # 删除30天前的消息
    cutoff = datetime.utcnow() - timedelta(days=30)
    db.query(ChatMessage).filter(ChatMessage.created_at < cutoff).delete()
    db.commit()
    print('已清理旧消息')
except Exception as e:
    print(f'清理失败: {e}')
finally:
    db.close()
" 2>/dev/null || echo -e "${RED}清理失败${NC}"
                echo -e "${GREEN}✓ 清理完成${NC}"
                ;;
            3)
                echo ""
                sqlite3 "$DB_PATH" ".tables" 2>/dev/null || echo "无法查看"
                ;;
            0)
                break
                ;;
        esac
    done
}

# 主循环
main() {
    # 检查是否为首次运行（需要安装）
    if [ ! -d $INSTALL_DIR ]; then
        echo -e "${RED}未检测到万岳AI客服系统${NC}"
        echo -e "${YELLOW}请先运行安装脚本：${NC}"
        echo "  bash $INSTALL_DIR/install.sh"
        exit 1
    fi
    
    while true; do
        show_copyright
        show_menu
        read choice
        
        case $choice in
            1)
                check_system
                ;;
            2)
                install_from_remote
                ;;
            3)
                change_domain
                ;;
            4)
                fix_system
                ;;
            5)
                restart_service
                ;;
            6)
                view_logs
                ;;
            7)
                service_manager
                ;;
            8)
                db_maintenance
                ;;
            9)
                echo ""
                echo -e "${YELLOW}将执行重新安装，系统数据将保留...${NC}"
                echo -ne "${GREEN}是否继续? [y/N]: ${NC}"
                read confirm
                if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
                    bash $INSTALL_DIR/install.sh
                fi
                ;;
            10)
                uninstall_system
                ;;
            0)
                echo ""
                echo -e "${GREEN}感谢使用万岳AI客服系统工具箱！${NC}"
                echo ""
                exit 0
                ;;
            *)
                echo -e "${RED}无效选项，请重新输入${NC}"
                sleep 1
                ;;
        esac
    done
}

